#, c-format
msgid ""
"Are you sure you want to delete notification settings for application "
"\"%s\"?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການລຶບການຕັ້ງຄ່າການແຈ້ງເຕືອນສຳລັບແອັບພລິເຄຊັນ \"%s\"?"

#: xfce4-notifyd-config/main.c:595
#: xfce4-notifyd-config/xfce-notify-log-viewer.c:930
msgid "Delete"
msgstr "ລຶບ"

