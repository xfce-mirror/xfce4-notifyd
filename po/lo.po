#: xfce4-notifyd-config/main.c:930
#, c-format
msgid ""
"<b>Currently only urgent notifications are shown.</b>\n"
"Notification logging is %s."
msgstr "<b>ປະຈຸບັນສະແດງສະເພາະການແຈ້ງເຕືອນທີ່ເລັ່ງດ່ວນເທົ່ານັ້ນ.</b>\nການບັນທຶກການແຈ້ງເຕືອນຄື %s."

#: xfce4-notifyd-config/main.c:937
msgid "enabled"
msgstr "ເປີດໃຊ້ງານ"

#: xfce4-notifyd-config/main.c:937
msgid "disabled"
msgstr "ປິດໃຊ້ງານ"

#: xfce4-notifyd-config/main.c:1173
msgid ""
"<big><b>Currently there are no known applications.</b></big>\n"
"As soon as an application sends a notification\n"
"it will appear in this list."
msgstr "<big><b>ປະຈຸບັນຍັງບໍ່ມີແອັບພລິເຄຊັນທີ່ຮູ້ຈັກ.</b></big>\nເມື່ອມີແອັບພລິເຄຊັນສົ່ງການແຈ້ງເຕືອນ\nມັນຈະປະກົດຂຶ້ນໃນລາຍການນີ້."

#: xfce4-notifyd-config/main.c:1242
msgid "Released under the terms of the GNU General Public License, version 2\n"
msgstr "ເຜີຍແຜ່ພາຍໃຕ້ເງື່ອນໄຂຂອງ GNU General Public License, ເວີຊັນ 2\n"

#: xfce4-notifyd-config/main.c:1243
#, c-format
msgid "Please report bugs to %s.\n"
msgstr "ກະລຸນາລາຍງານບັນຫາ (bug) ໄປທີ່ %s.\n"

#: xfce4-notifyd-config/main.c:1274
msgid "Settings daemon is unavailable"
msgstr "ເດມອນການຕັ້ງຄ່າບໍ່ສາມາດໃຊ້ງານໄດ້"

#: xfce4-notifyd-config/main.c:1376
msgid "Display version information"
msgstr "ສະແດງຂໍ້ມູນເວີຊັນ"

#: xfce4-notifyd-config/main.c:1377
msgid "Settings manager socket"
msgstr "ຊັອກເກັດຂອງຕົວຈັດການການຕັ້ງຄ່າ"

#: xfce4-notifyd-config/main.c:1377
msgid "SOCKET_ID"
msgstr "SOCKET_ID"

#: xfce4-notifyd-config/xfce-notify-log-viewer.c:176
msgid ""
"<big><b>Empty log</b></big>\n"
"No notifications have been logged yet."
msgstr "<big><b>ບັນທຶກຫວ່າງເປົ່າ</b></big>\nຍັງບໍ່ມີການບັນທຶກການແຈ້ງເຕືອນເທື່ອ."

#: xfce4-notifyd-config/xfce-notify-log-viewer.c:195
msgid "Refresh"
msgstr "ໂຫຼດໃໝ່"

#: xfce4-notifyd-config/xfce-notify-log-viewer.c:196
msgid "Refresh the notification log"
msgstr "ໂຫຼດບັນທຶກການແຈ້ງເຕືອນໃໝ່"

#: xfce4-notifyd-config/xfce-notify-log-viewer.c:205
msgid "Clear the notification log"
